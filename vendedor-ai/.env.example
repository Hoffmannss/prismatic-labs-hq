# Copie este arquivo para .env e preencha as chaves

# ---- LLM ----
# Groq (rapido e barato - recomendado)
GROQ_API_KEY=gsk_...

# OU OpenRouter (suporta varios modelos)
OPENROUTER_API_KEY=sk-or-...

# OU OpenAI
OPENAI_API_KEY=sk-...

# ---- APIFY (scout automatico) ----
# Conta gratuita em https://console.apify.com
# Settings -> API & Integrations -> API tokens
# Plano Free: U$5 de credito por mes (suficiente para ~500 leads/mes)
APIFY_API_TOKEN=apify_api_...

# ---- NOTION (CRM visual) ----
# Criar integracao em https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...
NOTION_PARENT_PAGE_ID=...  # Apenas para setup inicial

# ---- PRISMATIC LABS ----
INSTAGRAM_HANDLE=@labs.prismatic
EMAIL_CONTATO=labs.prismatic@gmail.com
WHATSAPP=5548984580234

# ---- AUTOPILOT (Modulo 10) ----
# Nicho padrao (opcoes: api-automacao, saude-bem-estar, ecommerce, etc.)
# Use: node 6-scout.js --list para ver todos os nichos disponiveis
AUTOPILOT_NICHO=api-automacao

# Quantos leads coletar por ciclo (quanto mais, mais credito Apify usa)
AUTOPILOT_QTD=20

# Quantos rodar pelo analyze/copywriter/reviewer (custo de tokens LLM)
AUTOPILOT_MAX_ANALYZE=10

# Sincronizar com Notion ao final do ciclo (true/false)
AUTOPILOT_SYNC_NOTION=true
