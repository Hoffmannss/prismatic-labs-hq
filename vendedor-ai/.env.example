# Copie este arquivo para .env e preencha as chaves

# ---- LLM ----
# Groq (rapido e barato - recomendado para Analyzer + Closer)
GROQ_API_KEY=gsk_...

# Google Gemini (GRATIS - recomendado para Copywriter + Learner)
# Criar em: https://aistudio.google.com/ -> Get API key
# 1.500 requests/dia grátis permanente, sem cartão
# IMPORTANTE: Agora usando gemini-1.5-flash-latest (auto-updated stable)
GOOGLE_API_KEY=AIza...

# OU OpenRouter (suporta vários modelos)
OPENROUTER_API_KEY=sk-or-...

# OU OpenAI
OPENAI_API_KEY=sk-...

# ---- INSTAGRAM SESSION ----
# Chave de criptografia AES-256-GCM para sessões do Instagram
# Gerar com: node agents/0-scraper.js rotate-key
SESSION_ENCRYPTION_KEY=sua_chave_64_chars_hex

# ---- NOTION (CRM visual) ----
# Criar integração em https://www.notion.so/my-integrations
NOTION_API_KEY=secret_...
NOTION_DATABASE_ID=...
NOTION_PARENT_PAGE_ID=...  # Apenas para setup inicial

# ---- PRISMATIC LABS ----
INSTAGRAM_HANDLE=@labs.prismatic
EMAIL_CONTATO=labs.prismatic@gmail.com
WHATSAPP=5548984580234

# ---- AUTOPILOT DIÁRIO (novo!) ----
# Horário de execução automática (formato 24h HH:MM)
AUTOPILOT_DAILY_HOUR=09:00

# Meta de leads por dia (recomendado: 10-20 para evitar rate limit)
AUTOPILOT_DAILY_TARGET=15

# Multiplicador de delays (3.0 = 3x mais lento, evita ban)
# Deixe em branco para usar padrão no autopilot manual
AUTOPILOT_DELAY_MULTIPLIER=

# ---- AUTOPILOT MANUAL (Módulo 10) ----
# Nicho padrão (opções: api-automacao, saude-bem-estar, ecommerce, etc.)
# Use: node 6-scout.js --list para ver todos os nichos disponíveis
AUTOPILOT_NICHO=api-automacao

# Quantos leads coletar por ciclo
AUTOPILOT_QTD=20

# Quantos rodar pelo analyze/copywriter/reviewer (custo de tokens LLM)
AUTOPILOT_MAX_ANALYZE=10

# Sincronizar com Notion ao final do ciclo (true/false)
AUTOPILOT_SYNC_NOTION=true

# ---- RATE LIMITING (avançado) ----
# Delay mínimo entre requests ao Instagram (ms)
MIN_DELAY_MS=1500

# Delay máximo entre requests ao Instagram (ms)
MAX_DELAY_MS=3500

# ---- DEBUG ----
# Ativar logs detalhados (true/false)
DEBUG=false

# Timezone do servidor
TZ=America/Sao_Paulo
