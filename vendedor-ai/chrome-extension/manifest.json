{
  "manifest_version": 3,
  "name": "Prismatic Connect",
  "version": "1.1.0",
  "description": "Conecte sua conta Instagram ao Vendedor AI e monitore respostas de DMs automaticamente.",
  "permissions": [
    "cookies",
    "storage",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
