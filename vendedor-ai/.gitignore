# =============================================================
# PRISMATIC LABS — VENDEDOR AI .gitignore
# =============================================================

# ---- SEGURANÇA (NUNCA commitar) ----
.env
.env.*
!.env.example
data/session/
*.json.enc

# ---- DADOS DE RUNTIME (regenerados automaticamente) ----
data/leads/
data/mensagens/
data/scout/
data/relatorios/
data/learning/
data/nichos-cache.json
data/autopilot-config.json
data/dm-queue.json
data/sender-config.json

# ---- CRM (dados sensíveis de leads) ----
# Commitar apenas a estrutura, nunca dados reais
data/crm/leads-database.json
data/crm/pipeline.json

# ---- LOGS ----
logs/
*.log
npm-debug.log*

# ---- NODE ----
node_modules/

# ---- SISTEMA OPERACIONAL ----
.DS_Store
Thumbs.db
._*

# ---- EDITORES ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- PLAYWRIGHT ----
playwright-state/
.auth/
playwright-report/
test-results/

# ---- BUILD / TEMPORÁRIOS ----
dist/
build/
.cache/
tmp/
temp/
*.tmp
